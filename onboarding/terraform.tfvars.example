# Copy to terraform.tfvars — do NOT commit terraform.tfvars to source control.
#
# idsec credentials (idsec_username / idsec_secret) must be supplied as
# TF_VAR_ environment variables sourced from Conjur via IAM auth.
# Do NOT put these values in this file.

# AWS & State
aws_region       = "us-east-2"
i_owner          = "your-name-or-team"
state_bucket     = "your-terraform-state-bucket"
state_key_prefix = "pineapple-oracle-db"

# Conjur — IAM host role authentication
# CONJUR_AUTHN_IAM_SERVICE_ID must also be set as an environment variable.
conjur_url         = "https://conjur.example.com"
conjur_account     = "myaccount"
conjur_authn_login = "host/aws/sts/my-terraform-role"

# Conjur paths for idsec provider credentials
conjur_idsec_username_path = "path/to/idsec/username"
conjur_idsec_secret_path   = "path/to/idsec/secret"

# idsec_username and idsec_secret are intentionally omitted here.
# Set them before running terraform apply:
#
#   export TF_VAR_idsec_username=$(conjur variable get \
#     -i "path/to/idsec/username")
#   export TF_VAR_idsec_secret=$(conjur variable get \
#     -i "path/to/idsec/secret")

# Privilege Cloud — safe
cyberark_safe_name               = "Oracle-DB-Safe"
create_cyberark_safe             = true
cyberark_safe_retention_days     = 7
cyberark_safe_retention_versions = 5
cyberark_cpm_name                = "PasswordManager"

# Privilege Cloud — account
cyberark_platform_id = "Oracle"

# Privilege Cloud — safe members (access policy for vaulted credential)
# permission_set: connect_only | read_only | approver | accounts_manager | full | custom
cyberark_access_members = {
  # "app-service@example.com" = { member_type = "User",  permission_set = "read_only" }
  # "dba-team"                = { member_type = "Group", permission_set = "full"      }
}

# SIA — strong account
idsec_strong_account_name_suffix = "strong"

# SIA — DB workspace
idsec_db_provider_engine        = "oracle-sh-vm"
idsec_db_configured_auth_method = "local_db_auth"

# SIA — DB access policy
idsec_policy_name             = "oracle-db-access-policy"
idsec_policy_timezone         = "America/New_York"
idsec_policy_max_session_duration = 8

# Oracle role grants for policy sessions
idsec_policy_oracle_dba_role     = false
idsec_policy_oracle_sysdba_role  = false
idsec_policy_oracle_sysoper_role = false
idsec_policy_oracle_roles        = ["CONNECT"]

# Principals that the policy applies to.
# type: USER | GROUP | ROLE
# source_directory_id / source_directory_name are required unless type is ROLE.
idsec_policy_principals = [
  # {
  #   id                    = "DBA_Role"
  #   name                  = "DbaRole"
  #   type                  = "ROLE"
  # },
  # {
  #   id                    = "jdoe@example.com"
  #   name                  = "John Doe"
  #   type                  = "USER"
  #   source_directory_id   = "your-directory-uuid"
  #   source_directory_name = "Active Directory"
  # }
]

