# Copy this file to backend.hcl and fill in your values.
# Initialize with: terraform init -backend-config=backend.hcl
#
# The S3 bucket must already exist. Bucket name is intentionally not
# committed to source control — supply it here or via TF_BACKEND_* env vars.

bucket  = "your-terraform-state-bucket"
key     = "pineapple-oracle-db/infrastructure/terraform.tfstate"
region  = "us-east-2"
encrypt = true

# Native S3 state locking (Terraform >= 1.10, no DynamoDB table required)
use_lockfile = true
